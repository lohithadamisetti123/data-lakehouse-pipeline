# Flask configuration
FLASK_APP=explorer.api.app
FLASK_ENV=development
FLASK_DEBUG=1
FLASK_HOST=0.0.0.0
FLASK_PORT=8000

# Lakehouse paths (inside container and local)
LAKEHOUSE_BASE_PATH=/app/data/lakehouse
SOURCE_BASE_PATH=/app/data/source

# CORS
CORS_ORIGINS=http://localhost:3000

# React UI
REACT_APP_API_BASE_URL=http://localhost:8000
